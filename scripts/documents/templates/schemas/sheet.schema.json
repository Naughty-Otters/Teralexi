{
  "$id": "sheet",
  "description": "Excel spreadsheet data",
  "required": ["title", "sheet"],
  "properties": {
    "title": { "type": "string" },
    "meta": {
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "date": { "type": "string" }
      }
    },
    "sheet": {
      "type": "object",
      "required": ["columns", "rows"],
      "properties": {
        "columns": { "type": "array" },
        "rows": { "type": "array" },
        "sheet_name": { "type": "string" }
      }
    }
  }
}
