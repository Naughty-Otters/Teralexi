{
  "$id": "report",
  "description": "Narrative report / Word brief / PDF report",
  "required": ["title", "sections"],
  "properties": {
    "title": { "type": "string" },
    "meta": {
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "date": { "type": "string" },
        "presenter": { "type": "string" }
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "heading": { "type": "string" },
          "body": { "type": "string" },
          "level": { "type": "number" }
        }
      }
    },
    "table": {
      "type": "object",
      "properties": {
        "headers": { "type": "array" },
        "rows": { "type": "array" }
      }
    }
  }
}
