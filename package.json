{
  "name": "openfde",
  "version": "0.0.1",
  "productName": "OpenFDE",
  "main": "./dist/electron/main/main.js",
  "author": "Naughty-Otters",
  "description": "OpenFDE project",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Naughty-Otters/OpenFDE.git"
  },
  "bugs": {
    "url": "https://github.com/Naughty-Otters/OpenFDE/issues"
  },
  "homepage": "https://github.com/Naughty-Otters/OpenFDE#readme",
  "scripts": {
    "dev": "tsx .electron-vite/dev-runner.ts -m dev",
    "build": "npm run icons:generate && tsx .electron-vite/build.ts -m prod && tsx scripts/run-electron-builder.ts -m prod -c build.json --publish never",
    "build:sit": "npm run icons:generate && tsx .electron-vite/build.ts -m sit && tsx scripts/run-electron-builder.ts -m sit -c build.json --publish never",
    "build:win32": "npm run icons:generate && tsx .electron-vite/build.ts -m prod  && tsx scripts/run-electron-builder.ts -m prod -c build.json --win  --ia32 --publish never",
    "build:win32:sit": "npm run icons:generate && tsx .electron-vite/build.ts -m sit  && tsx scripts/run-electron-builder.ts -m sit -c build.json --win  --ia32 --publish never",
    "build:win64": "npm run icons:generate && tsx .electron-vite/build.ts -m prod  && tsx scripts/run-electron-builder.ts -m prod -c build.json --win  --x64 --publish never",
    "build:win64:sit": "npm run icons:generate && tsx .electron-vite/build.ts -m sit  && tsx scripts/run-electron-builder.ts -m sit -c build.json --win  --x64 --publish never",
    "build:mac": "npm run icons:generate && tsx .electron-vite/build.ts -m prod  && tsx scripts/run-electron-builder.ts -m prod -c build.json --mac --publish never",
    "build:mac:sit": "npm run icons:generate && tsx .electron-vite/build.ts -m sit  && tsx scripts/run-electron-builder.ts -m sit -c build.json --mac --publish never",
    "build:linux": "npm run icons:generate && tsx .electron-vite/build.ts -m prod && tsx scripts/run-electron-builder.ts -m prod -c build.json --linux --publish never",
    "build:linux:sit": "npm run icons:generate && tsx .electron-vite/build.ts -m sit && tsx scripts/run-electron-builder.ts -m sit -c build.json --linux --publish never",
    "build:dir": "npm run icons:generate && tsx .electron-vite/build.ts -m prod  && tsx scripts/run-electron-builder.ts -m prod -c build.json --dir --publish never",
    "build:dir:sit": "npm run icons:generate && tsx .electron-vite/build.ts -m sit  && tsx scripts/run-electron-builder.ts -m sit -c build.json --dir --publish never",
    "analyze:pack-size": "du -sh build/mac-arm64/OpenFDE.app 2>/dev/null; du -sh build/mac-arm64/OpenFDE.app/Contents/Resources/app.asar build/mac-arm64/OpenFDE.app/Contents/Resources/app.asar.unpacked 2>/dev/null",
    "verify:signing": "node scripts/verify-signing.mjs",
    "build:clean": "tsx .electron-vite/build.ts --clean",
    "icons:generate": "node scripts/generate-app-icons.mjs",
    "build:web": "tsx .electron-vite/build.ts",
    "pack:resources": "tsx .electron-vite/hot-updater.ts",
    "postinstall": "electron-builder install-app-deps && patch-package",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "test": "npm run test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:watch": "vitest --config vitest.config.ts",
    "test:unit:coverage": "vitest run --config vitest.config.ts --coverage",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "release:mac": "npm run icons:generate && tsx .electron-vite/build.ts -m prod && tsx scripts/run-electron-builder.ts -m prod -c build.json --mac --publish never",
    "release:win": "npm run icons:generate && tsx .electron-vite/build.ts -m prod && tsx scripts/run-electron-builder.ts -m prod -c build.json --win --x64 --publish never",
    "release:upload-s3": "node .github/scripts/upload-release-to-s3.mjs build",
    "verify:mac-update": "node .github/scripts/verify-mac-update-manifest.mjs build"
  },
