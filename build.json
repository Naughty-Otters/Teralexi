{
  "asar": true,
  "asarUnpack": [
    "**/*.node",
    "**/node_modules/better-sqlite3/**",
    "**/node_modules/node-pty/**",
    "**/node_modules/esbuild/**",
    "**/node_modules/@esbuild/**",
    "dist/electron/skill-module-cache/**",
    "skills/**",
    "toolSet/**",
    "config/**",
    "src/main/**",
    "src/shared/**",
    "src/logging/**",
    "src/openfde-ai/**"
  ],
  "electronLanguages": [
    "en-US"
  ],
  "afterPack": ".electron-vite/after-pack.mjs",
  "extraFiles": [
    {
      "from": "build/icons",
      "to": "build/icons",
      "filter": [
        "**/*"
      ]
    }
  ],
  "publish": [
    {
      "provider": "github",
      "owner": "Naughty-Otters",
      "repo": "OpenFDE",
      "releaseType": "release"
    }
  ],
  "productName": "OpenFDE",
  "appId": "app.openfde.desktop",
  "directories": {
    "output": "build"
  },
  "files": [
    "dist/electron/**/*",
    "skills/**/*",
    "toolSet/**/*",
    "config/**/*",
    "src/main/**/*",
    "src/shared/**/*",
    "src/logging/**/*",
    "src/openfde-ai/**/*",
    "!**/*.{map,tsbuildinfo}",
    "!node_modules/monaco-editor/**",
    "!node_modules/mermaid/**",
    "!node_modules/@mermaid-js/**",
    "!node_modules/shiki/**",
    "!node_modules/@shikijs/**",
    "!node_modules/eslint/**",
    "!node_modules/prettier/**",
    "!node_modules/reka-ui/**",
    "!node_modules/vue/**",
    "!node_modules/vue-router/**",
    "!node_modules/@nuxt/**",
    "!node_modules/@vitejs/**",
    "!node_modules/vite/**",
    "!node_modules/vitest/**",
    "!node_modules/@vitest/**",
    "!node_modules/tailwindcss/**",
    "!node_modules/sass/**",
    "!node_modules/workflow/**",
    "!node_modules/@workflow/**",
    "!node_modules/jspdf/**",
    "!node_modules/javascript-obfuscator/**",
    "!node_modules/electron-devtools-vendor/**",
    "!node_modules/date-fns/**",
    "!node_modules/@eslint/**",
    "!node_modules/@vue/**",
    "!node_modules/{test,tests,__tests__,docs,examples,example}/**/*"
  ],
  "dmg": {
    "contents": [
      {
        "x": 410,
        "y": 150,
        "type": "link",
        "path": "/Applications"
      },
      {
        "x": 130,
        "y": 150,
        "type": "file"
      }
    ]
  },
  "mac": {
    "icon": "build/icons/icon.icns",
    "extendInfo": {
      "CFBundleDisplayName": "OpenFDE",
      "CFBundleName": "OpenFDE"
    },
    "target": [
      "dmg",
      "zip"
    ]
  },
  "win": {
    "icon": "build/icons/icon.ico",
    "target": [
      "nsis"
    ]
  },
  "linux": {
    "icon": "build/icons",
    "target": [
      "AppImage"
    ]
  }
}