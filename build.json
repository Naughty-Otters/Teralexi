{
  "asar": true,
  "asarUnpack": [
    "**/*.node",
    "**/node_modules/better-sqlite3/**",
    "**/node_modules/node-pty/**",
    "**/node_modules/esbuild/**",
    "**/node_modules/@esbuild/**",
    "dist/electron/skill-module-cache/**",
    "skills/**",
    "toolSet/**",
    "config/**",
    "src/main/**",
    "src/shared/**",
    "src/logging/**",
    "src/openfde-ai/**"
  ],
  "extraFiles": [
    {
      "from": "build/icons",
      "to": "build/icons",
      "filter": [
        "**/*"
      ]
    }
  ],
  "publish": [
    {
      "provider": "github",
      "owner": "Naughty-Otters",
      "repo": "OpenFDE",
      "releaseType": "release"
    }
  ],
  "productName": "OpenFDE",
  "appId": "app.openfde.desktop",
  "directories": {
    "output": "build"
  },
  "files": [
    "dist/electron/**/*",
    "skills/**/*",
    "toolSet/**/*",
    "config/**/*",
    "src/main/**/*",
    "src/shared/**/*",
    "src/logging/**/*",
    "src/openfde-ai/**/*"
  ],
  "dmg": {
    "contents": [
      {
        "x": 410,
        "y": 150,
        "type": "link",
        "path": "/Applications"
      },
      {
        "x": 130,
        "y": 150,
        "type": "file"
      }
    ]
  },
  "mac": {
    "icon": "build/icons/icon.icns",
    "extendInfo": {
      "CFBundleDisplayName": "OpenFDE",
      "CFBundleName": "OpenFDE"
    },
    "target": [
      "dmg",
      "zip"
    ]
  },
  "win": {
    "icon": "build/icons/icon.ico",
    "target": [
      "nsis"
    ]
  },
  "linux": {
    "icon": "build/icons",
    "target": [
      "AppImage"
    ]
  }
}