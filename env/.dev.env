# OpenFDE platform Google account sign-in URL (env-only; not in user settings).
BASE_API = 'http://127.0.0.1:25565'
NODE_ENV = 'development'
# Override config.properties defaults (also supports APP_METRICS_GRAPHQLURL)
app.metrics.graphqlUrl = 'http://127.0.0.1:8000/graphql'
APP_OPENFDE_GOOGLEAUTHLOGINURL=http://localhost:8000/auth/login
