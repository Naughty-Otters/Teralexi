# Local code signing (build-time only). Copy to env/.signing.env — never commit secrets.
# Used by npm run build:* and npm run release:* for both sit and prod local builds.
# CI/Release uses GitHub Actions secrets instead (see docs/CODE-SIGNING.md).

# macOS — Keychain identity (omit "Developer ID Application:" prefix, or paste full name)
# MAC_SIGN_IDENTITY = 'Your Name (TEAMID)'

# macOS — optional .p12 when cert is not in Keychain (CI uses base64 MAC_SIGN_CERTIFICATE)
# MAC_SIGN_CERTIFICATE = '~/certs/teralexi.p12'
# MAC_SIGN_CERTIFICATE_PASSWORD = 'your-p12-password'

# macOS notarization (production local releases)
# MAC_APPLE_ID = 'you@example.com'
# MAC_APPLE_APP_SPECIFIC_PASSWORD = 'xxxx-xxxx-xxxx-xxxx'
# MAC_APPLE_TEAM_ID = 'TEAMID'

# Windows Authenticode (.pfx file)
# WIN_SIGN_CERTIFICATE = '~/certs/teralexi.pfx'
# WIN_SIGN_CERTIFICATE_PASSWORD = 'your-pfx-password'

# Windows Azure Trusted Signing (remote; no .pfx file)
# See docs/CODE-SIGNING.md — https://hendrik-erz.de/post/code-signing-with-azure-trusted-signing-on-github-actions
# AZURE_TENANT_ID = 'your-entra-tenant-id'
# AZURE_CLIENT_ID = 'your-app-registration-client-id'
# AZURE_CLIENT_SECRET = 'your-app-registration-client-secret'
# AZURE_SIGNING_ENDPOINT = 'https://eus.codesigning.azure.net/'
# AZURE_SIGNING_ACCOUNT_NAME = 'your-artifact-signing-account'
# AZURE_SIGNING_CERTIFICATE_PROFILE = 'your-certificate-profile'
# AZURE_SIGNING_PUBLISHER_NAME = 'Your Legal Name'

# Optional: enable ARM profile existence check in npm run verify:azure-signing
# AZURE_SUBSCRIPTION_ID = 'your-subscription-guid'
# AZURE_RESOURCE_GROUP = 'your-resource-group-name'
