{
  "templates": [
    {
      "id": "corporate-report-pdf",
      "label": "Corporate report (PDF)",
      "doc_types": ["pdf"],
      "schema": "schemas/report.schema.json",
      "renderer": "html",
      "html": "html/corporate-report.html",
      "style": {
        "output_format": "pdf"
      }
    },
    {
      "id": "sales-dashboard",
      "label": "Sales dashboard (Excel)",
      "doc_types": ["excel"],
      "schema": "schemas/sheet.schema.json",
      "renderer": "excel",
      "style": {
        "theme": "corporate-blue",
        "sheet_name": "Summary",
        "chart": {
          "enabled": true,
          "type": "bar",
          "column": "Revenue"
        }
      }
    },
    {
      "id": "navy-roadmap-deck",
      "label": "Navy roadmap deck (PowerPoint)",
      "doc_types": ["powerpoint"],
      "schema": "schemas/deck.schema.json",
      "renderer": "powerpoint",
      "style": {
        "theme": "navy",
        "layout": "title-and-bullets"
      }
    },
    {
      "id": "formal-brief",
      "label": "Formal brief (Word)",
      "doc_types": ["word"],
      "schema": "schemas/report.schema.json",
      "renderer": "word",
      "style": {
        "doc_style": "formal"
      }
    }
  ]
}
